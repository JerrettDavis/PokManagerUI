@inherits LayoutComponentBase

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h5" Class="ml-3">PokManager</MudText>
        <MudSpacer />
        <ThemeToggle />
        <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                       Color="Color.Inherit"
                       Title="Notifications" />
        <MudMenu Icon="@Icons.Material.Filled.Person"
                 Color="Color.Inherit"
                 AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight">
            <MudMenuItem Icon="@Icons.Material.Filled.AccountCircle">Profile</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Settings">Settings</MudMenuItem>
            <MudDivider />
            <MudMenuItem Icon="@Icons.Material.Filled.Logout">Logout</MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="2"
               ClipMode="DrawerClipMode.Always">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6" Class="mt-1">
                <MudIcon Icon="@Icons.Material.Filled.Api" Class="mr-2" />
                Navigation
            </MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/"
                        Icon="@Icons.Material.Filled.Dashboard"
                        Match="NavLinkMatch.All">
                Dashboard
            </MudNavLink>
            <MudNavLink Href="/instances"
                        Icon="@Icons.Material.Filled.Dns">
                Instances
            </MudNavLink>
            <MudNavLink Href="/backups"
                        Icon="@Icons.Material.Filled.Backup">
                Backups
            </MudNavLink>
            <MudNavLink Href="/configuration"
                        Icon="@Icons.Material.Filled.Settings">
                Configuration
            </MudNavLink>
            <MudNavLink Href="/monitoring"
                        Icon="@Icons.Material.Filled.Monitor">
                Monitoring
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4 mb-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
